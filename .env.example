# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-safe-secret-key-here

# Keycloak Configuration (Production)
KEYCLOAK_URL=https://auth.myperformance.pl
KEYCLOAK_ISSUER=https://auth.myperformance.pl/realms/MyPerformance
KEYCLOAK_CLIENT_ID=dashboard-myperformance-pl
KEYCLOAK_CLIENT_SECRET=your-production-client-secret

# Keycloak Configuration (client-side)
NEXT_PUBLIC_KEYCLOAK_URL=https://auth.myperformance.pl
NEXT_PUBLIC_KEYCLOAK_ISSUER=https://auth.myperformance.pl/realms/MyPerformance
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=dashboard-myperformance-pl

# Keycloak Service Account (for credential management - 2FA, WebAuthn)
# Create a confidential client in Keycloak with:
#   - serviceAccountsEnabled: true
#   - Service Account Roles: realm-management -> manage-users
# If not set, falls back to KEYCLOAK_CLIENT_ID/SECRET
KEYCLOAK_SERVICE_CLIENT_ID=myperformance-service
KEYCLOAK_SERVICE_CLIENT_SECRET=your-service-client-secret

# Application Configuration
NODE_ENV=development
