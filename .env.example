# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-safe-secret-key-here

# Keycloak Configuration (Production)
KEYCLOAK_URL=https://auth.myperformance.pl
KEYCLOAK_CLIENT_ID=dashboard-myperformance-pl
KEYCLOAK_CLIENT_SECRET=ot0h8vUAQUJaTnbMyq0uNC0wcCt9Txg8
GOOGLE_IDP_CLIENT_ID=your-google-idp-client-id.apps.googleusercontent.com
GOOGLE_IDP_CLIENT_SECRET=your-google-idp-client-secret

# Keycloak Configuration (client-side)
NEXT_PUBLIC_KEYCLOAK_URL=https://auth.myperformance.pl
NEXT_PUBLIC_KEYCLOAK_ISSUER=https://auth.myperformance.pl/realms/MyPerformance
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=dashboard-myperformance-pl

# Keycloak Service Account (for Admin API calls: 2FA, WebAuthn, required-actions, passwordless)
# The dashboard-myperformance-pl client has serviceAccountsEnabled=true and
# realm-management roles (manage-users, view-users, query-users, manage-realm).
# If KEYCLOAK_SERVICE_CLIENT_ID is not set, falls back to KEYCLOAK_CLIENT_ID/SECRET.
# For production you may use a separate dedicated service client instead.
KEYCLOAK_SERVICE_CLIENT_ID=dashboard-myperformance-pl
KEYCLOAK_SERVICE_CLIENT_SECRET=ot0h8vUAQUJaTnbMyq0uNC0wcCt9Txg8

# Keycloak Webhook Configuration
# Secret for authenticating webhook requests from Keycloak
# Configure this same secret in Keycloak event webhook configuration
KEYCLOAK_WEBHOOK_SECRET=your-webhook-secret-here

# Application Configuration
NODE_ENV=development
NEXT_PUBLIC_APP_URL=https://myperformance.pl
