# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-strong-random-secret

# Keycloak Configuration
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=MyPerformance
KEYCLOAK_ISSUER=http://localhost:8080/realms/MyPerformance
KEYCLOAK_CLIENT_ID=myperformance-dashboard
KEYCLOAK_CLIENT_SECRET=replace-with-keycloak-client-secret
GOOGLE_IDP_CLIENT_ID=replace-with-google-idp-client-id.apps.googleusercontent.com
GOOGLE_IDP_CLIENT_SECRET=replace-with-google-idp-client-secret

# Keycloak Configuration (client-side / public)
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_ISSUER=http://localhost:8080/realms/MyPerformance
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=myperformance-dashboard

# Keycloak Service Account (for Admin API calls: 2FA, WebAuthn, required-actions, passwordless)
# The client should have serviceAccountsEnabled=true and
# realm-management roles (manage-users, view-users, query-users, manage-realm).
# If KEYCLOAK_SERVICE_CLIENT_ID is not set, falls back to KEYCLOAK_CLIENT_ID/SECRET.
# For production you may use a separate dedicated service client instead.
KEYCLOAK_SERVICE_CLIENT_ID=myperformance-service
KEYCLOAK_SERVICE_CLIENT_SECRET=replace-with-service-client-secret

# Keycloak Webhook Configuration
# Secret for authenticating webhook requests from Keycloak
# Configure this same secret in Keycloak event webhook configuration
KEYCLOAK_WEBHOOK_SECRET=replace-with-webhook-secret

# Webhook signing secret (>= 32 chars). Used to sign Google Calendar push channel
# IDs and encrypt stored refresh tokens at rest. Generate with:
#   openssl rand -base64 48
WEBHOOK_SIGNING_SECRET=replace-with->=32-char-random-secret

# Public HTTPS URL where Google Calendar push notifications are delivered.
# Must be reachable from the public internet and use HTTPS.
# Falls back to NEXTAUTH_URL when not set (only works if NEXTAUTH_URL is HTTPS).
PUBLIC_APP_URL=https://your-public-domain.example

# Kadromierz Integration
# Optional: company-wide master API key. When set, users connect with one
# click (matched by their verified Keycloak email). When empty, users paste
# their personal key. Obtain from Kadromierz owner profile → API tokens.
# KADROMIERZ_MASTER_API_KEY=
# KADROMIERZ_API_URL=https://api.kadromierz.pl/api

# Application Configuration
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
