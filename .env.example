# =====================================================================
# MyPerformance Dashboard — example environment
# Copy to `.env` and fill in secrets. Never commit real secrets.
# Placeholder values starting with `replace-with-` are detected by
# lib/env.ts at startup and will abort boot for critical vars.
# =====================================================================

# ---------------------------------------------------------------------
# NextAuth
# ---------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-strong-random-secret

# ---------------------------------------------------------------------
# Keycloak (server-side)
# ---------------------------------------------------------------------
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=MyPerformance
KEYCLOAK_ISSUER=http://localhost:8080/realms/MyPerformance
KEYCLOAK_CLIENT_ID=myperformance-dashboard
KEYCLOAK_CLIENT_SECRET=replace-with-keycloak-client-secret
GOOGLE_IDP_CLIENT_ID=replace-with-google-idp-client-id.apps.googleusercontent.com
GOOGLE_IDP_CLIENT_SECRET=replace-with-google-idp-client-secret

# Keycloak (client-side / public)
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_REALM=MyPerformance
NEXT_PUBLIC_KEYCLOAK_ISSUER=http://localhost:8080/realms/MyPerformance
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=myperformance-dashboard

# Keycloak Service Account (for Admin API calls: 2FA, WebAuthn, required-actions, passwordless)
# The client should have serviceAccountsEnabled=true and
# realm-management roles (manage-users, view-users, query-users, manage-realm).
# If KEYCLOAK_SERVICE_CLIENT_ID is not set, falls back to KEYCLOAK_CLIENT_ID/SECRET.
KEYCLOAK_SERVICE_CLIENT_ID=myperformance-service
KEYCLOAK_SERVICE_CLIENT_SECRET=replace-with-service-client-secret

# Shared secret for Keycloak event webhooks → /api/webhooks/keycloak.
# FAIL-CLOSED: if unset, the webhook endpoint returns 503.
KEYCLOAK_WEBHOOK_SECRET=replace-with-webhook-secret

# ---------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Surfaced in /api/health response and structured logs. Populate during
# image build (e.g. from git SHA) — defaults to "unknown".
NEXT_PUBLIC_APP_VERSION=dev
# NDJSON log level: debug | info | warn | error (default: info in prod, debug in dev)
LOG_LEVEL=info

# Webhook signing secret (>= 32 chars). Used to sign Google Calendar push channel
# IDs and encrypt stored refresh tokens at rest. Generate with:
#   openssl rand -base64 48
WEBHOOK_SIGNING_SECRET=replace-with->=32-char-random-secret

# Public HTTPS URL where Google Calendar push notifications are delivered.
# Must be reachable from the public internet and use HTTPS.
# Falls back to NEXTAUTH_URL when not set.
PUBLIC_APP_URL=https://your-public-domain.example

# Postgres connection string (calendar refresh-token store, persistence helpers).
# Leave blank to disable DB-backed persistence (files under ./.data are used).
DATABASE_URL=

# ---------------------------------------------------------------------
# SMTP (outbound mail) — primary transport is internal Postal relay.
# See infrastructure/postal/README.md for credential sourcing and
# scripts/postal-propagate-smtp.mjs for pushing these envs across every
# service in the stack.
# ---------------------------------------------------------------------
SMTP_HOST=smtp-iut9wf1rz9ey54g7lbkje0je
SMTP_PORT=25
SMTP_SECURE=false
SMTP_USER=main
SMTP_PASSWORD=replace-with-postal-credential-key
CERT_EMAIL_FROM_NAME=MyPerformance
CERT_EMAIL_FROM_ADDRESS=noreply@myperformance.pl

# ---------------------------------------------------------------------
# Postal propagation script inputs (see scripts/postal-propagate-smtp.mjs)
# ---------------------------------------------------------------------
# POSTAL_INTERNAL_SMTP_HOST=smtp-iut9wf1rz9ey54g7lbkje0je
# POSTAL_INTERNAL_SMTP_PORT=25
# POSTAL_INTERNAL_SMTP_USER=main
# POSTAL_INTERNAL_SMTP_PASS=
# POSTAL_SMTP_FROM=MyPerformance <noreply@myperformance.pl>
# POSTAL_SMTP_SECURE=false
# POSTAL_REDEPLOY=0
# COOLIFY_DASHBOARD_UUID=
# COOLIFY_DOCUMENSO_UUID=
# COOLIFY_CHATWOOT_UUID=
# COOLIFY_DIRECTUS_UUID=
# COOLIFY_OUTLINE_UUID=
# COOLIFY_MOODLE_UUID=
# COOLIFY_LISTMONK_UUID=
# COOLIFY_POSTAL_UUID=

# ---------------------------------------------------------------------
# Kadromierz integration
# Optional: company-wide master API key. When set, users connect with one
# click (matched by their verified Keycloak email). When empty, users paste
# their personal key. Obtain from Kadromierz owner profile → API tokens.
# ---------------------------------------------------------------------
KADROMIERZ_MASTER_API_KEY=
KADROMIERZ_API_URL=https://api.kadromierz.pl/api

# ---------------------------------------------------------------------
# Documenso (e-podpis przez SSO bridge — /api/documenso/sso)
# ---------------------------------------------------------------------
DOCUMENSO_URL=https://sign.myperformance.pl
NEXT_PUBLIC_DOCUMENSO_URL=https://sign.myperformance.pl
DOCUMENSO_API_KEY=
# HMAC secret used to verify incoming Documenso webhooks (configured in
# Documenso → Settings → Webhooks pointing at myperformance.pl/api/webhooks/documenso).
DOCUMENSO_WEBHOOK_SECRET=
# Direct Postgres URL to Documenso's database — used by /api/documenso/sso to
# sync `User.roles` (USER vs ADMIN) based on which dashboard tile was clicked,
# and by the DocumensoProvider (lib/permissions) when the metarole panel
# assigns/removes admin rights across the stack.
# Read from the Documenso service env `NEXT_PRIVATE_DATABASE_URL` in Coolify.
# Leave blank to disable role sync.
DOCUMENSO_DB_URL=

# ---------------------------------------------------------------------
# Postal (direct MariaDB URL — used by PostalProvider in the IAM panel
# because Postal's HTTP API does not expose user-role endpoints).
# Format: mysql://USER:PASS@postal-mariadb:3306/postal
# ---------------------------------------------------------------------
POSTAL_DB_URL=

# ---------------------------------------------------------------------
# Chatwoot (support chat integration)
# Platform-level API token (Chatwoot → Platform Apps). Used to mint
# magic-link SSO URLs for Keycloak-authenticated users and to drive
# the Chatwoot provider in the /admin/users permission editor
# (custom_roles + account_users).
# ---------------------------------------------------------------------
CHATWOOT_URL=https://chat.myperformance.pl
CHATWOOT_PLATFORM_TOKEN=
CHATWOOT_ACCOUNT_ID=1

# ---------------------------------------------------------------------
# Moodle (Academy integration)
# Web services token — user "dashboard-api" with role containing
# core_role_get_roles, core_role_assign_roles, core_role_unassign_roles,
# core_user_get_users_by_field, core_user_create_users. Drives the
# Moodle provider in /admin/users (single-role-per-area enforcement).
# ---------------------------------------------------------------------
MOODLE_URL=https://academy.myperformance.pl
MOODLE_API_TOKEN=

# ---------------------------------------------------------------------
# Directus (headless CMS integration)
# Admin-scoped static token (Directus → Users → Generate token on a
# user with the Administrator role). Used both by
# scripts/directus-seed-clients.mjs and by the Directus provider in
# /admin/users (listPermissions + roles CRUD + assignUserRole).
# ---------------------------------------------------------------------
DIRECTUS_URL=https://cms.myperformance.pl
DIRECTUS_ADMIN_TOKEN=

# ---------------------------------------------------------------------
# step-ca (client cert issuance for cert-gated panels)
# ---------------------------------------------------------------------
# Public base URL of the step-ca server (no trailing slash).
STEP_CA_URL=https://ca.myperformance.pl
# Name of the JWK provisioner used to sign OTT tokens.
STEP_CA_PROVISIONER_NAME=admin@myperformance.pl
# Password that decrypts the JWK provisioner's encryptedKey.
STEP_CA_PROVISIONER_PASSWORD=replace-with-provisioner-password
# JSONL append-only file where issued / revoked certs are recorded.
# Mount this path on a persistent volume in production.
CERT_REGISTRY_PATH=/data/certs.json
# JSONL append-only file with admin audit events (issue / revoke / errors).
AUDIT_LOG_PATH=/data/audit.log
# PEM-encoded admin mTLS credentials used for the step-ca admin API
# (revocation). Provision once via `step ca admin add` with an admin role.
STEP_CA_ADMIN_CERT_PEM=
STEP_CA_ADMIN_KEY_PEM=

# Device-fingerprint gate for cert-gated panels.
# Each panel calls POST /api/cert-gate with the cert serial + fingerprint
# components; on first use the fingerprint is bound to the cert, on change
# the request is blocked and the admin sees the diff in /admin/certificates.
# CERT_GATE_URL on panels must point at this dashboard's endpoint.
CERT_GATE_SECRET=replace-with-long-random-secret
# For the panels (set in each panel's Coolify env, not this dashboard):
#   CERT_GATE_URL=https://myperformance.pl/api/cert-gate
#   CERT_GATE_SECRET=<same value as above>

# ---------------------------------------------------------------------
# Postal (transactional mail server — optional, currently unused in prod)
# ---------------------------------------------------------------------
# POSTAL_URL=https://postal.myperformance.pl
# POSTAL_API_KEY=
# POSTAL_SMTP_HOST=smtp.postal.myperformance.pl
# POSTAL_SMTP_PORT=587
# POSTAL_SMTP_USER=
# POSTAL_SMTP_PASSWORD=

# ---------------------------------------------------------------------
# Panel OIDC clients (confidential). Secrets are per-client in Keycloak.
# Used by docker-compose.dev.yml when bringing up all panels on localhost
# (sprzedawca:3001, serwisant:3002, kierowca:3003).
# ---------------------------------------------------------------------
PANEL_SPRZEDAWCA_CLIENT_SECRET=
PANEL_SERWISANT_CLIENT_SECRET=
PANEL_KIEROWCA_CLIENT_SECRET=

# ---------------------------------------------------------------------
# Coolify deploy (used only by scripts/coolify-deploy.sh; never baked
# into container images). Populate on the machine that triggers deploys.
# ---------------------------------------------------------------------
COOLIFY_BASE_URL=https://coolify.myperformance.pl
COOLIFY_API_TOKEN=
COOLIFY_DASHBOARD_UUID=
COOLIFY_SPRZEDAWCA_UUID=
COOLIFY_SERWISANT_UUID=
COOLIFY_KIEROWCA_UUID=

# ---------------------------------------------------------------------
# Service URLs — public-facing addresses dla integracji + linków w UI.
# Fail-closed: brak env = panel/funkcja niedostępna z explicit błędem.
# ---------------------------------------------------------------------
# URL panelu Wazuh OpenSearch Dashboards. Używany przez /admin/infrastructure
# dla linków + CSP allowlist (next.config.js).
NEXT_PUBLIC_WAZUH_URL=https://wazuh.myperformance.pl

# Public brand URL (Caseownia / Serwis telefonów) — używany w mailach
# typu "kopia podpisanego potwierdzenia" jako link do śledzenia zlecenia.
BRAND_URL=https://zlecenieserwisowe.pl

# Public-facing URL natywnych admin paneli — propagowany do AREAS dla
# nativeAdminUrl (Chatwoot agents, Moodle roles, Outline members itd.).
NEXT_PUBLIC_CHATWOOT_URL=https://chat.myperformance.pl
NEXT_PUBLIC_MOODLE_URL=https://moodle.myperformance.pl
NEXT_PUBLIC_DIRECTUS_URL=https://cms.myperformance.pl
NEXT_PUBLIC_DOCUMENSO_URL=https://sign.myperformance.pl
NEXT_PUBLIC_OUTLINE_URL=https://knowledge.myperformance.pl
NEXT_PUBLIC_POSTAL_URL=https://postal.myperformance.pl

# ---------------------------------------------------------------------
# OpenTelemetry (opcjonalne — gdy ustawione, włącza auto-instr fetch/http/
# pg/mysql/dns. Fail-closed: bez OTEL_EXPORTER_OTLP_ENDPOINT SDK nie startuje).
# ---------------------------------------------------------------------
# Pełen URL kolektora OTLP/HTTP. Przykłady:
#   - SigNoz Cloud:  https://ingest.eu.signoz.cloud:443
#   - Grafana Cloud Tempo:  https://tempo-eu-west-0.grafana.net/tempo
#   - Lokalny Jaeger:  http://localhost:4318
#   - Lokalny otel-collector:  http://otel-collector:4318
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_SERVICE_NAME=myperformance-dashboard
# OTEL_EXPORTER_OTLP_HEADERS=signoz-access-token=replace-me
# OTEL_RESOURCE_ATTRIBUTES_DEPLOYMENT_ENVIRONMENT=production
