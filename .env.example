# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-safe-secret-key-here

# Keycloak Configuration
# Local development: http://localhost:8080/realms/MyPerformance
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_ISSUER=http://localhost:8080/realms/MyPerformance
KEYCLOAK_CLIENT_ID=dashboard-local
KEYCLOAK_CLIENT_SECRET=your-client-secret

# Keycloak Configuration (client-side)
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=dashboard-local

# Application Configuration
NODE_ENV=development
