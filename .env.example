# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-change-in-production

# Keycloak Configuration
KEYCLOAK_URL=https://auth.myperformance.pl/realms/MyPerformance
KEYCLOAK_CLIENT_ID=dashboard-myperformance-pl
KEYCLOAK_CLIENT_SECRET=your-client-secret-here

# Keycloak Configuration (client-side)
NEXT_PUBLIC_KEYCLOAK_URL=https://auth.myperformance.pl/realms/MyPerformance
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=dashboard-myperformance-pl

# Application Configuration
NODE_ENV=development
