      "identityProviderMapper": "google-user-attribute-mapper",
      "config": {
        "syncMode": "FORCE",
        "user.attribute": "lastName",
        "jsonField": "family_name"
      }
    }
  ],

  "clientScopes": [
    {
      "name": "phone",
      "description": "OpenID Connect built-in scope: phone (mapped to custom 'phone-number' attribute)",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true",
        "consent.screen.text": "${phoneScopeConsentText}"
      },
      "protocolMappers": [
        {
          "name": "phone number",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "introspection.token.claim": "true",
            "userinfo.token.claim": "true",
            "user.attribute": "phone-number",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "phone_number",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],

  "clients": [
    {
      "clientId": "myperformance-dashboard",
      "name": "MyPerformance Dashboard",
      "description": "Next.js dashboard client (browser + server-side BFF)",
      "rootUrl": "${NEXT_PUBLIC_APP_URL}",
      "adminUrl": "${NEXT_PUBLIC_APP_URL}",
      "baseUrl": "/",
      "enabled": true,
      "alwaysDisplayInConsole": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "${KEYCLOAK_CLIENT_SECRET}",
      "redirectUris": [
        "http://localhost:3000/*",
        "https://myperformance.pl/*",
        "https://www.myperformance.pl/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "https://myperformance.pl",
        "https://www.myperformance.pl"
      ],
      "notBefore": 0,
      "bearerOnly": false,
      "consentRequired": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "publicClient": false,
      "frontchannelLogout": true,
      "protocol": "openid-connect",
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:3000/*##https://myperformance.pl/*##https://www.myperformance.pl/*",
        "oauth2.device.authorization.grant.enabled": "false",
        "oidc.ciba.grant.enabled": "false",
        "backchannel.logout.session.required": "true",
        "backchannel.logout.revoke.offline.tokens": "false",
        "client.session.idle.timeout": "0",
        "client.session.max.lifespan": "0",
        "display.on.consent.screen": "false",
        "tls.client.certificate.bound.access.tokens": "false"
      },
      "authenticationFlowBindingOverrides": {},
      "fullScopeAllowed": true,
      "nodeReRegistrationTimeout": -1,
      "protocolMappers": [
        {
          "name": "phone-number",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "introspection.token.claim": "true",
            "userinfo.token.claim": "true",
            "user.attribute": "phone-number",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "phone_number",
            "jsonType.label": "String"
          }
        },
        {
          "name": "audience-dashboard",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "myperformance-dashboard",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "introspection.token.claim": "true"
          }
        }
      ],
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "basic",
        "email"
      ],
      "optionalClientScopes": [
        "offline_access",
        "phone",
        "address",
        "microprofile-jwt"
      ]
    },
