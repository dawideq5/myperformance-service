# Upload Bridge — env reference (Wave 22 / F16c).
#
# Plik czysto dokumentacyjny. Aktualne zmienne idą do Coolify (per-app env).
# `.env.local` w upload-bridge jest gitignore'owany przez root .gitignore.

# ---------------------------------------------------------------------
# Origin głównego dashboardu — używany do CSP `connect-src` (status checks
# / hand-off API). W prod: https://myperformance.pl. W dev nie wymagane.
DASHBOARD_URL=https://myperformance.pl

# ---------------------------------------------------------------------
# WebSocket URL self-hosted serwera LiveKit. Klient publishera w
# `/livestream` woła `room.connect(NEXT_PUBLIC_LIVEKIT_URL, token)`.
# `NEXT_PUBLIC_*` jest inlinowany przy buildzie — brak fallback na
# runtime, musi być ustawione w środowisku build.
#
# Origin tego hosta jest też dodawany do CSP `connect-src` w
# `next.config.js` (czytany w build-time), więc bez tego stream nie
# zadziała w prod (CSP zablokuje wss).
NEXT_PUBLIC_LIVEKIT_URL=wss://livekit.myperformance.pl
