{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "schedule:weekly",
    ":semanticCommits",
    ":dependencyDashboard",
    "group:allNonMajor",
    "group:linters"
  ],
  "labels": ["dependencies"],
  "prHourlyLimit": 4,
  "prConcurrentLimit": 6,
  "rangeStrategy": "bump",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 5am on Monday"]
  },
  "vulnerabilityAlerts": {
    "labels": ["security", "dependencies"],
    "schedule": [],
    "prHourlyLimit": 0,
    "prConcurrentLimit": 0
  },
  "packageRules": [
    {
      "description": "Pin Next.js + React major — wymaga manualnego review",
      "matchPackageNames": ["next", "react", "react-dom", "next-auth"],
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true
    },
    {
      "description": "TypeScript major — manualny review",
      "matchPackageNames": ["typescript"],
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true
    },
    {
      "description": "Auto-merge dev deps minor/patch po passing CI",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true,
      "automergeType": "branch"
    },
    {
      "description": "Auto-merge linters/formatters",
      "matchPackageNames": [
        "eslint",
        "eslint-config-next",
        "@typescript-eslint/eslint-plugin",
        "prettier"
      ],
      "automerge": true,
      "automergeType": "branch"
    },
    {
      "description": "Docker image base updates — sprawdź security advisories ręcznie",
      "matchManagers": ["dockerfile"],
      "dependencyDashboardApproval": true
    }
  ],
  "ignorePaths": [
    "**/node_modules/**",
    "**/.next/**",
    "build_keycloak/**",
    "panels/*/node_modules/**"
  ],
  "postUpdateOptions": ["npmDedupe"]
}
