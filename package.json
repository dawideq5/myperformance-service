{
  "name": "myperformance-dashboard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "bash scripts/dev-hybrid.sh",
    "dev:panels": "bash scripts/dev-hybrid.sh --panels",
    "dev:bare": "PORT=3000 next dev",
    "dev:db": "docker compose -f docker-compose.dev.yml up -d postgres-dev",
    "dev:db:stop": "docker compose -f docker-compose.dev.yml stop postgres-dev",
    "dev:db:reset": "docker compose -f docker-compose.dev.yml down -v && docker compose -f docker-compose.dev.yml up -d postgres-dev",
    "build": "next build",
    "dev:keycloak-theme": "vite",
    "build:keycloak-theme-app": "vite build",
    "build-keycloak-theme": "npm run build:keycloak-theme-app && keycloakify build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "dev:webhooks": "bash scripts/tunnel-webhooks.sh",
    "deploy": "bash scripts/promote-to-prod.sh"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.74.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.216.0",
    "@opentelemetry/sdk-node": "^0.216.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@types/node-forge": "^1.3.14",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "clsx": "^2.1.0",
    "jose": "^6.2.2",
    "keycloakify": "^11.15.3",
    "leaflet": "^1.9.4",
    "livekit-client": "^2.18.8",
    "livekit-server-sdk": "^2.15.2",
    "lucide-react": "^0.344.0",
    "mysql2": "^3.22.2",
    "next": "^15.0.0",
    "next-auth": "^4.24.0",
    "node-forge": "^1.4.0",
    "nodemailer": "^8.0.5",
    "otpauth": "^9.5.0",
    "pdfkit": "^0.18.0",
    "pg": "^8.13.1",
    "qrcode": "^1.5.4",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-leaflet": "^5.0.0",
    "react-phone-number-input": "^3.4.16",
    "recharts": "^2.12.0",
    "tailwind-merge": "^2.2.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20.11.0",
    "@types/nodemailer": "^6.4.15",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.5.15",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^8.0.8",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "@emnapi/core": "1.9.2",
    "@emnapi/runtime": "1.9.2",
    "uuid": "^14.0.0"
  }
}
